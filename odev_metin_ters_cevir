# odev_metin_ters_cevir.py

# ==========================================
# Bölüm A - Temel Çözüm
# ==========================================
def ters_cevir(metin):
    ters_metin = ""
    sayac = 0
    
    # Karakterleri baştan sona dolaşıp yeni string'in en başına ekliyoruz 
    # (Bu sayede mantıken sondan başa doğru dizilmiş oluyorlar)
    for harf in metin:
        ters_metin = harf + ters_metin
        sayac += 1
        
    print(f"[Temel Çözüm] İşlenen karakter: {sayac} | Metin uzunluğu: {len(metin)}")
    return ters_metin

# ==========================================
# Bölüm B - İndeks Kullanarak Çözüm
# ==========================================
def ters_cevir_index(metin):
    ters_metin = ""
    sayac = 0
    
    # range(başlangıç, bitiş, adım) kullanarak son indeksten sıfıra doğru geliyoruz
    for i in range(len(metin) - 1, -1, -1):
        ters_metin += metin[i]
        sayac += 1
        
    print(f"[İndeks Çözüm] İşlenen karakter: {sayac} | Metin uzunluğu: {len(metin)}")
    return ters_metin

# ==========================================
# Bölüm C - While Döngüsü ile Çözüm
# ==========================================
def ters_cevir_while(metin):
    ters_metin = ""
    sayac = 0
    i = len(metin) - 1
    
    while i >= 0:
        ters_metin += metin[i]
        sayac += 1
        i -= 1
        
    print(f"[While Çözüm] İşlenen karakter: {sayac} | Metin uzunluğu: {len(metin)}")
    return ters_metin


