# Bölüm E - Testler (15 Test)
# ==========================================
if __name__ == "__main__":
    print("--- 15 ADET TEST SENARYOSU ---")
    test_metinleri = [
        "a",                                    # 1. Tek harf
        "ab",                                   # 2. İki harf
        "abc",                                  # 3. Üç harf
        "12345",                                # 4. Sadece sayılar
        "Python",                               # 5. İstenen örnek
        "",                                     # 6. Boş metin
        " ",                                    # 7. Sadece boşluk
        "Veri Yapıları",                        # 8. İki kelime
        "123abc",                               # 9. Sayı ve harf
        "!!!",                                  # 10. Sadece özel karakter
        "Bu çok uzun bir cümledir ve test için yazılmıştır.", # 11. Uzun cümle
        "BÜYÜK HARFLİ METİN",                   # 12. Büyük harfli metin
        "küçük harfli metin",                   # 13. Küçük harfli metin
        "A1b2C3d4!!!",                          # 14. Sayı, harf, özel karakter karışık
        "x" * 100                               # 15. 100 karakterlik metin
    ]

    for index, test in enumerate(test_metinleri, start=1):
        print(f"\nTest {index} Girdi: '{test}'")
        # Farklı yöntemlerin çalıştığını göstermek için fonksiyonları dönüşümlü kullanalım
        if index % 3 == 1:
            cikti = ters_cevir(test)
        elif index % 3 == 2:
            cikti = ters_cevir_index(test)
        else:
            cikti = ters_cevir_while(test)
            
        # 100 karakterlik testi ekrana basarken terminali boğmamak için kısa gösterelim
        if index == 15:
            print(f"Çıktı (Kısaltılmış): '{cikti[:10]}...{cikti[-10:]}'")
        else:
            print(f"Çıktı: '{cikti}'")

    print("\n" + "="*40)
    
    # ==========================================
    # Bölüm F - Kullanıcıdan Girdi Alma
    # ==========================================
    print("\n--- KULLANICI GİRİŞİ ---")
    kullanici_metni = input("Metin giriniz: ")
    print("Tersi:", ters_cevir(kullanici_metni))


